{
  "title": "StreamGate — NFT Gated Streaming",
  "uid": "streamgate",
  "tags": ["streamgate", "web3", "nft"],
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "title": "NFT 验证速率",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(rate(streamgate_nft_verify_total{result=\"true\"}[5m])) by (chain_id)",
          "legendFormat": "{{chain_id}} ✅",
          "refId": "A"
        },
        {
          "expr": "sum(rate(streamgate_nft_verify_total{result=\"false\"}[5m])) by (chain_id)",
          "legendFormat": "{{chain_id}} ❌",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {"lineInterpolation": "smooth"}
        }
      }
    },
    {
      "title": "NFT 验证 P99 延迟 (秒)",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(streamgate_nft_verify_duration_seconds_bucket[5m])) by (le, chain_id))",
          "legendFormat": "{{chain_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"lineInterpolation": "smooth"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 1}, {"color": "red", "value": 2}]}
        }
      }
    },
    {
      "title": "缓存命中分布",
      "type": "piechart",
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 8},
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "sum(increase(streamgate_nft_cache_hits_total[1h])) by (tier)",
          "legendFormat": "{{tier}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Reorg 失效数",
      "type": "stat",
      "gridPos": {"x": 8, "y": 8, "w": 4, "h": 8},
      "datasource": "prometheus",
      "targets": [
        {"expr": "increase(streamgate_nft_verify_reorg_invalidated_total[1h])", "refId": "A"}
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "background"}}
      }
    },
    {
      "title": "Playback 令牌分发",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8},
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "rate(streamgate_playback_token_issued_total[5m])",
          "legendFormat": "tokens/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps"}
      }
    },
    {
      "title": "RPC 调用延迟 P99 (秒)",
      "type": "timeseries",
      "gridPos": {"x": 0, "y": 16, "w": 12, "h": 8},
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(streamgate_rpc_latency_seconds_bucket[5m])) by (le, operation))",
          "legendFormat": "{{operation}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {"lineInterpolation": "smooth"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}
        }
      }
    },
    {
      "title": "RPC Failover 次数",
      "type": "timeseries",
      "gridPos": {"x": 12, "y": 16, "w": 12, "h": 8},
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "rate(streamgate_rpc_failover_total[5m])",
          "legendFormat": "failover/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "ops"}
      }
    },
    {
      "title": "RPC Endpoint 评分",
      "type": "table",
      "gridPos": {"x": 0, "y": 24, "w": 24, "h": 8},
      "datasource": "prometheus",
      "targets": [
        {
          "expr": "streamgate_rpc_score",
          "legendFormat": "{{url}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {"align": "left"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": 0}, {"color": "yellow", "value": 0.5}, {"color": "green", "value": 0.8}]}
        }
      }
    }
  ],
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"}
}
