# StreamGate Environment Configuration
# Copy this file to .env and fill in your values

# === Database (Required) ===
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=streamgate
DATABASE_SSLMODE=disable
DATABASE_MAXCONNS=25

# === Redis (Required) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# === Object Storage (Required) ===
STORAGE_TYPE=minio
STORAGE_ENDPOINT=localhost:9000
STORAGE_ACCESSKEY=minioadmin
STORAGE_SECRETKEY=minioadmin
STORAGE_BUCKET=streamgate
STORAGE_REGION=

# === NATS (Required for microservice mode) ===
NATS_URL=nats://localhost:4222

# === Consul (Required for microservice mode) ===
CONSUL_HOST=localhost
CONSUL_PORT=8500

# === Web3 / Blockchain (Required for NFT features) ===
WEB3_ETHEREUM_RPC=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
WEB3_SOLANA_RPC=https://api.mainnet-beta.solana.com

# === Auth (Required - MUST change in production) ===
AUTH_JWT_SECRET=streamgate-dev-secret
# Comma-separated list for key rotation: first is signing key, rest verify only
# AUTH_JWT_SECRETS=new-secret,old-secret

# === Web3 / Blockchain (Required for NFT features) ===
WEB3_ETHEREUM_RPC=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
WEB3_SOLANA_RPC=https://api.mainnet-beta.solana.com
# WEB3_SOLANA_RPC_FALLBACK=https://solana-api.projectserum.com

# === gRPC (Optional, TLS) ===
# GRPC_TLS_ENABLED=false
# GRPC_TLS_CERT=/path/to/cert.pem
# GRPC_TLS_KEY=/path/to/key.pem

# === Rate Limiting ===
# Per-wallet rate limit (requests per minute)
# WALLET_RATE_LIMIT=10

# === Monitoring (Optional) ===
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# === Environment ===
STREAMGATE_ENV=development
